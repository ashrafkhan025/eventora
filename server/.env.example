MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
JWT_SECRET=replace_with_a_long_random_secret
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# Optional sender override.
# EMAIL_FROM="Eventora <your_email@gmail.com>"
# Optional: use these if your host/email provider needs explicit SMTP settings.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# Optional: use Resend if your deployment provider blocks SMTP.
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL="Eventora <onboarding@resend.dev>"
PORT=5000
